#!/bin/sh
# .husky/commit-msg
# Enforces:
#   1. Conventional commit format (via commitlint)
#   2. DCO Signed-off-by trailer (mandatory for all contributors)

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# ── 1. Commitlint (conventional commits) ────────────────────────────
npx --no-install commitlint --edit "$COMMIT_MSG_FILE"
LINT_EXIT=$?

if [ $LINT_EXIT -ne 0 ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  ❌  Commit message does not follow Conventional Commits.    ║"
  echo "║                                                              ║"
  echo "║  Valid format:  <type>(<scope>): <subject>                   ║"
  echo "║  Examples:                                                   ║"
  echo "║    feat(core): add batch compiler size enforcement           ║"
  echo "║    fix(react): resolve circular import in ChronosProvider    ║"
  echo "║    docs: update README quickstart example                    ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  exit 1
fi

# ── 2. DCO Signed-off-by trailer ───────────────────────────────────
if ! grep -qE "^Signed-off-by: .+ <.+@.+>" "$COMMIT_MSG_FILE"; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  ❌  Missing DCO Signed-off-by trailer.                     ║"
  echo "║                                                              ║"
  echo "║  Add it automatically with:  git commit -s                  ║"
  echo "║                                                              ║"
  echo "║  Or amend the last commit:   git commit --amend -s          ║"
  echo "║                                                              ║"
  echo "║  Required format:                                            ║"
  echo "║    Signed-off-by: Your Name <you@example.com>               ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  exit 1
fi

echo "✅ Commit message valid (conventional commits + DCO sign-off present)."
